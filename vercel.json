{
  "rewrites": [
    { "source": "/api/(.*)",   "destination": "/api/$1" },
    { "source": "/p",        "destination": "/index.html" },
    { "source": "/privacidad", "destination": "/privacidad.html" },
    { "source": "/terminos",   "destination": "/terminos.html" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
